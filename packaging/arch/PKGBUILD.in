pkgname=cockpit-router-admin
pkgver=VERSION
pkgrel=1
pkgdesc='Cockpit router administration dashboard'
arch=('x86_64')
url='https://github.com/local/router-admin'
license=(LGPL)
source=("SOURCE")
sha256sums=('SKIP')

package() {
  depends=(cockpit)
  cd $pkgname
  make DESTDIR="$pkgdir" install PREFIX=/usr
}
